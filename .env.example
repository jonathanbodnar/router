# Your OpenRouter API key — used to actually call the underlying models.
OPENROUTER_API_KEY=sk-or-v1-...

# The API key clients (e.g. Cursor) must send to this router.
# Generate something long and random.
ROUTER_API_KEY=replace-me-with-a-long-random-string

# Password for the /dashboard UI (HTTP Basic, username "admin").
# Defaults to ROUTER_API_KEY if unset.
DASHBOARD_PASSWORD=

# Where the SQLite call log lives. On Railway, mount a volume and point this
# at it (e.g. /data/router.db) so the log survives redeploys.
DATABASE_PATH=./router.db

# Optional. Railway sets PORT automatically; this is just a local default.
PORT=8787

# Optional. Sent to OpenRouter as HTTP-Referer / X-Title (helps OpenRouter
# attribute traffic and unlock some leaderboards).
OPENROUTER_SITE_URL=https://your-app.up.railway.app
OPENROUTER_APP_TITLE=cursor-auto-router

# Optional. Set to "1" to log routing decisions to stdout.
ROUTER_LOG=1

# Internal/testing: override the OpenRouter base URL (default
# https://openrouter.ai/api/v1). Used by scripts/http-smoke.ts to point at
# a local fake. You should not set this in production.
# OPENROUTER_BASE_URL=
