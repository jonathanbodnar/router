# Your OpenRouter API key — used for the agentic / code / reasoning tiers
# (MiMo and the Claude models).
OPENROUTER_API_KEY=sk-or-v1-...

# Your Fireworks API key — used for the cheap tier (DeepSeek V4 Pro).
FIREWORKS_API_KEY=fw_...

# Optional. Per-1M-token prices for the Fireworks-hosted DeepSeek V4 Pro
# model, used to compute cost for the dashboard. Defaults are placeholders
# (input=$0.50, output=$1.50) — update to whatever Fireworks is actually
# charging you.
# PRICE_DEEPSEEK_V4_INPUT=0.50
# PRICE_DEEPSEEK_V4_OUTPUT=1.50

# The API key clients (e.g. Cursor) must send to this router.
# Generate something long and random.
ROUTER_API_KEY=replace-me-with-a-long-random-string

# Password for the /dashboard UI (HTTP Basic, username "admin").
# Defaults to ROUTER_API_KEY if unset.
DASHBOARD_PASSWORD=

# Where the SQLite call log lives. On Railway, mount a volume and point this
# at it (e.g. /data/router.db) so the log survives redeploys.
DATABASE_PATH=./router.db

# Optional. Railway sets PORT automatically; this is just a local default.
PORT=8787

# Optional. Sent to OpenRouter as HTTP-Referer / X-Title (helps OpenRouter
# attribute traffic and unlock some leaderboards).
OPENROUTER_SITE_URL=https://your-app.up.railway.app
OPENROUTER_APP_TITLE=cursor-auto-router

# Optional. Set to "1" to log routing decisions to stdout.
ROUTER_LOG=1

# Optional one-shot debug. Set to "1" to log the FULL upstream request
# (URL, headers minus the API key, body) and response (status, body
# preview) for every chat-completions call. Use this to see exactly what
# OpenRouter / Fireworks is being sent and what it returns. Don't leave
# on in production — it's noisy and includes user prompts.
# ROUTER_LOG_UPSTREAM=1

# Optional. Hybrid LLM classifier — when the heuristic is uncertain (medium
# size, no strong signal) we ask a cheap LLM to label the task as easy /
# moderate / hard, and upgrade to Sonnet/Opus if it says so. Set to "0" to
# disable and rely purely on heuristics.
# ROUTER_LLM_CLASSIFIER=1
# ROUTER_LLM_CLASSIFIER_TIMEOUT_MS=1500
# ROUTER_LLM_CLASSIFIER_MIN_TOKENS=800
# ROUTER_LLM_CLASSIFIER_MAX_TOKENS=8000

# Optional. Circuit breaker — after this many consecutive failures from an
# upstream model we skip it for COOLDOWN_MS and route straight to Sonnet.
# Stops Cursor's BYOK proxy from tripping its rate-limiter on a flapping
# upstream.
# ROUTER_BREAKER_FAILS=3
# ROUTER_BREAKER_COOLDOWN_MS=60000

# Internal/testing: override upstream base URLs. Used by
# scripts/http-smoke.ts to point at a local fake. You should not set these
# in production.
# OPENROUTER_BASE_URL=
# FIREWORKS_BASE_URL=
